<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="in_square_seo.configurator.og" class="InSquare\SeoBundle\Seo\Og\OgSeoConfigurator">
            <argument>%in_square_seo.og%</argument>
        </service>

        <service id="in_square_seo.generator.og" class="InSquare\SeoBundle\Seo\Og\OgSeoGenerator">
            <argument id="in_square_seo.builder" type="service"/>
            <configurator service="in_square_seo.configurator.og" method="configure" />
            <tag name="in_square_seo.generator" alias="og"/>
        </service>

        <!-- for autowiring -->
        <service id="InSquare\SeoBundle\Seo\Og\OgSeoGenerator" alias="in_square_seo.generator.og" />
    </services>
</container>
